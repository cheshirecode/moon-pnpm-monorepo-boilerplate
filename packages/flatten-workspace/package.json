{
  "name": "@cheshirecode/flatten-workspace",
  "version": "0.0.0",
  "description": "Flatten dependency fields from workspace package manifests into one package manifest.",
  "type": "module",
  "private": false,
  "keywords": [
    "workspace",
    "monorepo",
    "package-json"
  ],
  "author": "cheshireCode <1631630+cheshirecode@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate.git",
    "directory": "packages/flatten-workspace"
  },
  "bugs": {
    "url": "https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate/issues"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "flatten-workspace": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "oxlint src --ignore-path ../../.gitignore --quiet"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
