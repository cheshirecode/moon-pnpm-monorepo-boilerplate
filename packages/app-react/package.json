{
  "name": "app-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./microfrontend": {
      "types": "./src/entry-microfrontend.d.ts",
      "import": "./src/entry-microfrontend.tsx"
    }
  },
  "scripts": {
    "dev": "node dev.ts",
    "dev:prod": "node build.js && node dist/server/node.js",
    "start": "node dist/server/node.js",
    "preview": "node dist/server/node.js",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "build": "node build.js",
    "build:client:production": "vite build --config vite.client.config.ts",
    "build:server": "vite build --config vite.config.server.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write {**/*,*}.{js,ts,jsx,tsx} --ignore-path .gitignore",
    "lint": "oxlint src --ignore-path ../../.gitignore --quiet"
  },
  "dependencies": {
    "@cheshirecode/hono-base": "workspace:^",
    "@hono/node-server": "^1.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "hono": "^4.9.0",
    "@cheshirecode/browser-clipboard": "workspace:^",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "classnames": "^2.5.1",
    "fast-json-stable-stringify": "^2.1.0",
    "lodash-es": "^4.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-select": "^5.10.2",
    "regexparam": "^3.0.0",
    "swr": "^2.4.2",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@cheshirecode/eslint-config-react": "workspace:^",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@unocss/vite": "^66.7.4",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "sass": "^1.101.0",
    "storybook": "^10.5.0",
    "typescript": "^7.0.2",
    "unocss": "^66.7.4",
    "unocss-preset-scrollbar": "^4.0.0",
    "vite": "^8.1.2",
    "vite-plugin-importus": "^1.0.5",
    "vitest": "^4.1.9",
    "@faker-js/faker": "^10.5.0",
    "@unocss/preset-mini": "^66.7.4",
    "miragejs": "^0.1.48"
  }
}
