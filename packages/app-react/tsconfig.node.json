{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "src/server",
    "unocss.config.ts",
    "src/styles/grid.ts",
    "vite.config.ts",
    "vite.client.config.ts",
    "vite.config.server.ts",
    "build.js",
    "alias.ts"
  ]
}
