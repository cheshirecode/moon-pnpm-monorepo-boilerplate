{
  "name": "@cheshirecode/browser-clipboard",
  "version": "0.0.0",
  "description": "Browser clipboard helpers with textarea fallback",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "oxlint src --ignore-path ../../.gitignore --quiet",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@cheshirecode/tsconfig": "workspace:^",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "license": "MIT"
}
