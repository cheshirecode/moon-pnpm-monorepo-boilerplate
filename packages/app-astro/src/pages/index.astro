---
import { astroDemoContract, astroDemoText } from '../demo';
---

<html lang="en">
  <head>
    <title>{astroDemoContract.title} — showcase demo</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
        color: oklch(0.29 0.03 265);
        background: oklch(0.985 0.004 95);
      }
      .page {
        max-width: 640px;
        margin: 0 auto;
        padding: clamp(32px, 5vw, 72px) clamp(20px, 4vw, 40px);
      }
      .back-link {
        color: inherit;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 24px;
        font-size: 13px;
        opacity: 0.65;
        position: relative;
        transition: opacity 150ms ease-out;
      }
      .back-link::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -1px;
        height: 1px;
        background: currentColor;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 200ms ease-out;
      }
      .back-link:hover { opacity: 1; }
      .back-link:hover::after { transform: scaleX(1); }
      main {
        border-top: 3px solid oklch(0.62 0.2 25);
        padding-top: 24px;
      }
      h1 {
        margin: 0 0 8px;
        font-size: clamp(24px, 4vw, 36px);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
      }
      p {
        margin: 0 0 8px;
        font-size: 14px;
        line-height: 1.6;
        color: oklch(0.53 0.02 265);
      }
    </style>
  </head>
  <body>
    <div class="page">
      <a href="/" class="back-link">← Back to showcase</a>
      <main>
        <h1>{astroDemoContract.title}</h1>
        <p>{astroDemoText}</p>
        <p>{astroDemoContract.url}</p>
      </main>
    </div>
  </body>
</html>
