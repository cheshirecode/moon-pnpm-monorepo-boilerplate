{
  "name": "@cheshirecode/eslint-config-react",
  "version": "0.3.0",
  "description": "common eslint + prettier config for React with workaround for its own dependencies",
  "keywords": [
    "eslint",
    "eslint-config",
    "react",
    "prettier",
    "linting"
  ],
  "sideEffects": true,
  "main": "index.js",
  "files": [
    "index.js",
    ".prettierrc.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate.git",
    "directory": "packages/eslint-config-react"
  },
  "author": "cheshireCode <1631630+cheshirecode@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "test": "vitest run --config vitest.config.mjs",
    "coverage": "vitest run --coverage --config vitest.config.mjs",
    "format": "prettier --write index.js",
    "lint": "oxlint . --ignore-path ../../.gitignore --ignore-pattern 'fails/**' --quiet"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.9"
  },
  "bugs": {
    "url": "https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate/issues"
  },
  "homepage": "https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate/tree/main/packages/eslint-config-react#readme",
  "description": "common eslint + prettier config for React with workaround for its own dependencies",
  "engines": {
    "node": ">=24.11.0"
  }
}
