{
  "name": "@cheshirecode/create-moon-pnpm-monorepo",
  "version": "0.0.0",
  "description": "Create a clean moon, pnpm, and Changesets monorepo from this boilerplate's tooling.",
  "type": "module",
  "private": false,
  "keywords": [
    "monorepo",
    "moonrepo",
    "pnpm",
    "changesets"
  ],
  "author": "cheshireCode <1631630+cheshirecode@users.noreply.github.com>",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate.git",
    "directory": "packages/create-moon-pnpm-monorepo"
  },
  "bugs": {
    "url": "https://github.com/cheshirecode/moon-pnpm-monorepo-boilerplate/issues"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "create-moon-pnpm-monorepo": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "oxlint src --ignore-path ../../.gitignore --quiet",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@cheshirecode/tsconfig": "workspace:^",
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
