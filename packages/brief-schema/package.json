  },
  "scripts": {
    "test": "vitest run index.test.js",
    "coverage": "vitest run --coverage",
    "lint": "oxlint . --ignore-path ../../.gitignore --quiet"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "vitest": "^4.1.9"
  }
}
