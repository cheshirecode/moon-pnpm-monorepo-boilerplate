{
  "name": "moon-pnpm-monorepo-boilerplate",
  "private": true,
  "engines": {
    "node": ">=24.11.0"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@changesets/cli": "^2.31.0",
    "@moonrepo/cli": "^2.3.4",
    "oxlint": "^1.70.0"
  },
  "scripts": {
    "setup": "pnpm install --frozen-lockfile",
    "moon": "moon",
    "lint:fast": "oxlint packages tests --ignore-path .gitignore --ignore-pattern '**/node_modules/**' --ignore-pattern 'packages/eslint-config-react/fails/**' --quiet",
    "lint": "moon run :lint",
    "typecheck": "moon run :typecheck",
    "build": "moon run :build",
    "test": "moon run :test && vitest run",
    "coverage": "moon run :coverage",
    "ci": "pnpm run lint:fast && moon ci :lint :typecheck :build :test && vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "pack": "node scripts/pack-publishable.mjs",
    "publish-packages": "changeset publish"
  },
  "packageManager": "pnpm@11.8.0",
  "workspaces": [
    "packages/*"
  ]
}
